# Copy this file to .env in the same directory and fill in real values.
# SECRET_KEY MUST be identical across all four backend/*/.env files —
# SimpleJWT signs/verifies tokens with it, so identity-service and the
# other three services have to agree or cross-service auth breaks.
SECRET_KEY=

DB_NAME=SLIS THESIS FINAL
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Comma-separated list of origins allowed to make credentialed requests.
# Defaults to the Vite dev server if left unset.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
