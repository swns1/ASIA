# Copy this file to .env in the same directory and fill in real values.
# SECRET_KEY MUST be identical across all four backend/*/.env files —
# SimpleJWT signs/verifies tokens with it.
SECRET_KEY=

DB_NAME=SLIS THESIS FINAL
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# AI / third-party integrations used by the ai/ and enrollments/ apps.
# Rotate these at the provider dashboard before reusing — see instructions doc.
GEMINI_API_KEY=
GROQ_API_KEY=
RESEND_API_KEY=
